<resources>
    <!-- Base application theme hardcoded to Dark -->
    <style name="Theme.Inventarizace" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="android:forceDarkAllowed">true</item>
    </style>

    <!-- Splash Screen Theme -->
    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/graphite_core</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/splash_icon</item>
        <item name="postSplashScreenTheme">@style/Theme.Inventarizace</item>
    </style>
</resources>
